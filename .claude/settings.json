{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'root=$(git rev-parse --show-toplevel 2>/dev/null || echo .); bash \"$root/.claude/hooks/check-changelog.sh\"'",
            "timeout": 15,
            "statusMessage": "Checking CHANGELOG gate..."
          }
        ]
      }
    ]
  }
}
